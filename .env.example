APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api

APP_NAME=shelfflow-local
JWT_SECRET=change-me
JWT_EXPIRES_IN=PT12H
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://127.0.0.1:3001

SHELFFLOW_ADMIN_HOST=127.0.0.1
SHELFFLOW_ADMIN_PORT=3000
SHELFFLOW_USER_WEB_HOST=127.0.0.1
SHELFFLOW_USER_WEB_PORT=3001
SHELFFLOW_GATEWAY_BASE_URL=http://127.0.0.1:4010

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=shelfflow
DB_USER=root
DB_PASSWORD=change-me

AI_OPS_PROVIDER=dashscope
AI_OPS_MODEL=qwen-plus
AI_OPS_API_KEY=
AI_OPS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
AI_OPS_CHAT_COMPLETIONS_PATH=/v1/chat/completions
AI_OPS_REQUEST_TIMEOUT_SECONDS=30
AI_OPS_MAX_TOKENS=1200
AI_OPS_TEMPERATURE=0.2

SHELFFLOW_MAIL_ENABLED=false
SHELFFLOW_MAIL_HOST=smtp.163.com
SHELFFLOW_MAIL_PORT=465
SHELFFLOW_MAIL_USERNAME=
SHELFFLOW_MAIL_PASSWORD=
SHELFFLOW_MAIL_FROM=
SHELFFLOW_MAIL_FROM_NAME=ShelfFlow
SHELFFLOW_MAIL_SUBJECT=ShelfFlow 验证码
SHELFFLOW_MAIL_SSL=true
SHELFFLOW_MAIL_STARTTLS=false
USER_AUTH_EXPOSE_DEBUG_VERIFICATION_CODE=false
