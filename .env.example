APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api

APP_NAME=shelfflow-local
JWT_SECRET=change-me
JWT_EXPIRES_IN=PT12H
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://127.0.0.1:3001

SHELFFLOW_ADMIN_HOST=127.0.0.1
SHELFFLOW_ADMIN_PORT=3000
SHELFFLOW_USER_WEB_HOST=127.0.0.1
SHELFFLOW_USER_WEB_PORT=3001
SHELFFLOW_GATEWAY_BASE_URL=http://127.0.0.1:4010

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=shelfflow
DB_USER=root
DB_PASSWORD=change-me

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=1
REDIS_TIMEOUT_MS=2000
USER_ORDER_INVENTORY_RESERVATION_MODE=database
USER_ORDER_INVENTORY_REDIS_KEY_PREFIX=shelfflow:inventory:batch
USER_ORDER_INVENTORY_RESERVATION_TTL_SECONDS=900
USER_ORDER_INVENTORY_RESERVATION_FAIL_OPEN=false
USER_CATALOG_CACHE_ENABLED=false
USER_CATALOG_CACHE_CATEGORIES_TTL_SECONDS=120
USER_CATALOG_CACHE_PRODUCTS_TTL_SECONDS=60
USER_CATALOG_CACHE_FAIL_OPEN=true
ADMIN_STOREFRONT_CACHE_INVALIDATION_ENABLED=false
ADMIN_STOREFRONT_CACHE_SCAN_COUNT=200
ADMIN_STOREFRONT_CACHE_FAIL_OPEN=true
STOREFRONT_CATALOG_CACHE_REDIS_KEY_PREFIX=shelfflow:storefront:catalog

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_VIRTUAL_HOST=/
RABBITMQ_PUBLISHER_CONFIRM_TYPE=correlated
RABBITMQ_PUBLISHER_RETURNS=true
USER_ORDER_EVENTS_ENABLED=false
USER_ORDER_EVENTS_EXCHANGE=shelfflow.order.events
USER_ORDER_EVENTS_ROUTING_KEY_PREFIX=shelfflow.order
USER_ORDER_EVENTS_DURABLE_EXCHANGE=true
USER_ORDER_EVENTS_FAIL_FAST=false
ADMIN_ORDER_EVENTS_CONSUMER_ENABLED=false
ADMIN_ORDER_EVENTS_CONSUMER_QUEUE=shelfflow.admin.order-events.inbox
ADMIN_ORDER_EVENTS_CONSUMER_ROUTING_KEY=shelfflow.order.*
ADMIN_ORDER_EVENTS_CONSUMER_DURABLE_EXCHANGE=true
ADMIN_ORDER_EVENTS_CONSUMER_DURABLE_QUEUE=true
ADMIN_ORDER_EVENTS_CONSUMER_FAIL_FAST=true
USER_ORDER_TIMEOUT_CLOSE_ENABLED=false
USER_ORDER_TIMEOUT_CLOSE_UNPAID_TIMEOUT_MINUTES=30
USER_ORDER_TIMEOUT_CLOSE_FIXED_DELAY_MILLISECONDS=60000
USER_ORDER_TIMEOUT_CLOSE_BATCH_SIZE=100
USER_ORDER_TIMEOUT_CLOSE_CANCEL_REASON=订单超时未支付，系统自动取消
USER_ORDER_PAYMENT_CALLBACK_ENABLED=false
USER_ORDER_PAYMENT_CALLBACK_REQUIRE_SIGNATURE=true
# 开启支付回调时必须配置，不要提交真实密钥
USER_ORDER_PAYMENT_CALLBACK_SECRET=

SHELFFLOW_FLYWAY_BASELINE_ON_MIGRATE=true
SHELFFLOW_FLYWAY_BASELINE_VERSION=202605000000
SHELFFLOW_FLYWAY_VALIDATE_ON_MIGRATE=true
SHELFFLOW_FLYWAY_OUT_OF_ORDER=false
SHELFFLOW_FLYWAY_SCHEMA_HISTORY_TABLE=flyway_schema_history

SHELFFLOW_NACOS_ENABLED=false
SHELFFLOW_NACOS_CONFIG_ENABLED=false
SHELFFLOW_NACOS_CONFIG_REFRESH_ENABLED=true
SHELFFLOW_NACOS_SERVER_ADDR=127.0.0.1:8848
SHELFFLOW_NACOS_NAMESPACE=
SHELFFLOW_NACOS_GROUP=DEFAULT_GROUP
SHELFFLOW_NACOS_SHARED_DATA_ID=shelfflow-common.yaml
NACOS_HTTP_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_RAFT_PORT=9849

SHELFFLOW_SENTINEL_ENABLED=false
SHELFFLOW_SENTINEL_EAGER=true
SHELFFLOW_SENTINEL_DASHBOARD=127.0.0.1:8858
SENTINEL_DASHBOARD_PORT=8858
SHELFFLOW_SENTINEL_AUTH_LOGIN_QPS=20
SHELFFLOW_SENTINEL_USER_CATALOG_QPS=120
SHELFFLOW_SENTINEL_USER_CART_QPS=80
SHELFFLOW_SENTINEL_USER_ORDERS_QPS=40
SHELFFLOW_SENTINEL_USER_VERIFY_CODE_QPS=10
SHELFFLOW_SENTINEL_ADMIN_PRODUCTS_QPS=80
SHELFFLOW_SENTINEL_ADMIN_BATCHES_QPS=60
SHELFFLOW_SENTINEL_ADMIN_ORDERS_QPS=60
SHELFFLOW_SENTINEL_ADMIN_AI_CHAT_QPS=5
SHELFFLOW_SENTINEL_GATEWAY_INTERVAL_SECONDS=1
SHELFFLOW_SENTINEL_GATEWAY_USER_QPS=150
SHELFFLOW_SENTINEL_GATEWAY_AUTH_QPS=50
SHELFFLOW_SENTINEL_GATEWAY_AI_QPS=10

AI_OPS_PROVIDER=dashscope
AI_OPS_MODEL=qwen-plus
AI_OPS_API_KEY=
AI_OPS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
AI_OPS_CHAT_COMPLETIONS_PATH=/v1/chat/completions
AI_OPS_REQUEST_TIMEOUT_SECONDS=30
AI_OPS_MAX_TOKENS=1200
AI_OPS_TEMPERATURE=0.2

SHELFFLOW_MAIL_ENABLED=false
SHELFFLOW_MAIL_HOST=smtp.163.com
SHELFFLOW_MAIL_PORT=465
SHELFFLOW_MAIL_USERNAME=
SHELFFLOW_MAIL_PASSWORD=
SHELFFLOW_MAIL_FROM=
SHELFFLOW_MAIL_FROM_NAME=ShelfFlow
SHELFFLOW_MAIL_SUBJECT=ShelfFlow 验证码
SHELFFLOW_MAIL_SSL=true
SHELFFLOW_MAIL_STARTTLS=false
USER_AUTH_EXPOSE_DEBUG_VERIFICATION_CODE=false
