AI_OPS_TEMPERATURE=0.2
AI_OPS_SUGGESTION_LIMIT=20
AI_OPS_RETRIEVAL_LIMIT=4

SHELFFLOW_DOCKER_PROJECT=shelfflow
SHELFFLOW_INFRA_SERVICES="mysql redis rabbitmq"
