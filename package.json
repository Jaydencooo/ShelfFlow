{
  "name": "shelfflow",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:admin-web": "npm run dev -w @shelfflow/admin-web",
    "dev:user-web": "npm run dev -w @shelfflow/user-web",
    "smoke:admin-web-ui": "bash scripts/admin-web-ui-smoke.sh",
    "smoke:user-web-ui": "bash scripts/user-web-ui-smoke.sh",
    "seed:user-demo": "bash scripts/seed-user-demo-data.sh"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
