<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.shelfflow.mapper.ProductSpecMapper">
    <insert id="insertBatch" parameterType="com.shelfflow.entity.ProductSpec">
        insert into product_spec(product_id, name, value) VALUES
        <foreach collection="list" item="productSpec" separator=",">
            (#{productSpec.productId}, #{productSpec.name}, #{productSpec.value})
        </foreach>
    </insert>
</mapper>